# Echo Avatar Fusion — environment template
# Copy to .env.local (gitignored) and fill in values. Never commit real keys.
#
# The app also stores keys in browser localStorage via Settings.
# Vite only exposes variables prefixed with VITE_

# OpenAI — Whisper, GPT, TTS, optional DALL-E fallback
# https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# Replicate — optional Wav2Lip / video (requires backend proxy for browser CORS)
# https://replicate.com/account/api-tokens
VITE_REPLICATE_API_TOKEN=

# Ollama — local LLM / image models (default http://127.0.0.1:11434)
VITE_OLLAMA_HOST=http://127.0.0.1:11434
VITE_OLLAMA_IMAGE_MODEL=x/z-image-turbo
